<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.hwcho99.niftyMomnt.indexBatch</string>
		<string>com.hwcho99.niftyMomnt.refresh</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>niftyMomnt</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>NSAppleMusicUsageDescription</key>
	<string>niftyMomnt remembers what you were listening to when you capture a moment.</string>
	<key>NSCameraUsageDescription</key>
	<string>niftyMomnt uses your camera to capture moments.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>niftyMomnt uses Face ID to protect your private vault. Only you can access your private shots.</string>
	<key>NSJournalingSuggestionsUsageDescription</key>
	<string>niftyMomnt surfaces your life context as nudges to help you remember and reflect on moments worth capturing.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>niftyMomnt uses your location to tag moments and organise your journal.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>niftyMomnt records ambient sound for Echo and Atmosphere moments, and uses a brief audio buffer at Still capture to tag the ambient vibe of the moment (Sound Stamp). Audio is never stored or shared.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>niftyMomnt saves Live Photos to your photo library when you export them.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>niftyMomnt transcribes your voice notes on-device to create text.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
		<string>fetch</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations~iphone</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
